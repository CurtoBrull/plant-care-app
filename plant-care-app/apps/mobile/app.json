{
  "expo": {
    "name": "Plant Care",
    "slug": "plant-care-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "plant-care",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.plantcare.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.plantcare.app"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Necesitamos acceso a tus fotos para añadirlas a tus plantas.",
          "cameraPermission": "Necesitamos acceso a la cámara para fotografiar tus plantas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
